# Copia a .env (en esta misma carpeta) y llena tus valores reales. NUNCA subas .env a git.
# Se invoca con:  node --env-file=.env scripts/generate-event-report.js ...

# Obligatorio — Apify (https://console.apify.com/settings/integrations -> "Personal API token")
APIFY_TOKEN=

# Nota: NO se necesita OPENROUTER_API_KEY. El texto del reporte lo redacta el agente de Claude
# que corre esta skill (paso "prepare" -> agente escribe el JSON -> paso "finalize"), sin llamar
# a ningun LLM externo.

# Obligatorio — Supabase: URL base del proyecto (SIN /rest/v1/ al final) + la service key.
# La tabla `reports` necesita la columna jsonb `subject_config` (ver supabase_schema.sql del
# proyecto principal, o corre: alter table reports add column if not exists subject_config jsonb;)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=
